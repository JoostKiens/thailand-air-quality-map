{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env.local --import=tsx/esm --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:firms": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-firms.ts",
    "ingest:aqi": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-aqi.ts",
    "ingest:wind": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-wind.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@supabase/supabase-js": "^2.45.0",
    "@thailand-aq/types": "workspace:*",
    "@upstash/redis": "^1.34.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
