{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env.local --import=tsx/esm --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:firms": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-firms.ts",
    "ingest:aqi": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-aqi.ts",
    "ingest:aqi:today": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-aqi-today.ts",
    "ingest:weather": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-weather.ts",
    "ingest:weather:today": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-weather-today.ts",
    "ingest:aq": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-aq.ts",
    "ingest:aq:today": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-aq-today.ts",
    "prune": "node --env-file=.env.local --import=tsx/esm src/scripts/prune.ts",
    "ingest:stations": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-stations.ts",
    "ingest:power-plants": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-power-plants.ts",
    "railway:ingest:firms": "node --import=tsx/esm src/scripts/ingest-firms.ts",
    "railway:ingest:aqi": "node --import=tsx/esm src/scripts/ingest-aqi.ts",
    "railway:ingest:aqi:today": "node --import=tsx/esm src/scripts/ingest-aqi-today.ts",
    "railway:ingest:stations": "node --import=tsx/esm src/scripts/ingest-stations.ts",
    "railway:ingest:weather:today": "node --import=tsx/esm src/scripts/ingest-weather-today.ts",
    "railway:ingest:aq:today": "node --import=tsx/esm src/scripts/ingest-aq-today.ts",
    "railway:prune": "node --import=tsx/esm src/scripts/prune.ts"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^10.1.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.45.0",
    "@thailand-aq/types": "workspace:*",
    "@upstash/redis": "^1.34.0",
    "csv-parse": "^5.5.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "p-retry": "^6.0.0",
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
